{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build SFML",
      "command": "/usr/bin/clang++",
      "args": [
        "-std=c++17",
        "-I",
        "/opt/homebrew/opt/sfml/include",
        "-L",
        "/opt/homebrew/opt/sfml/lib",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ],
  "version": "2.0.0"
}